OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_OUTPUT_TOKENS=700
OPENAI_TIMEOUT=60

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tn-agriculture-schemes-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

SOURCE_URL=https://www.tn.gov.in/scheme_list.php?dep_id=Mg==
SCHEMES_LANDING_URL=https://www.tn.gov.in/schemes.php

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVER_K=4
MAX_INPUT_CHARS=1200
MAX_HISTORY_MESSAGES=50

REQUEST_TIMEOUT=30
REQUEST_RETRIES=3
REQUEST_DELAY_SECONDS=1

DATA_DIRECTORY=data

# Neo4j Aura Knowledge Graph — get from https://console.neo4j.io
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_INDEX_NAME=scheme_chunks

APP_ENV=development
# Protects Refresh / Rebuild / data-replacing actions. In production with
# ADMIN_ACTIONS_ENABLED=true you MUST set a non-empty ADMIN_PASSWORD.
ADMIN_ACTIONS_ENABLED=true
ADMIN_PASSWORD=
